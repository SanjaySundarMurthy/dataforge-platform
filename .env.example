# ============================================================
# DataForge Platform - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# ============================================================

# ── Project ──────────────────────────────────────────────────
PROJECT_NAME=dataforge
ENVIRONMENT=local

# ── Azure (for cloud deployment) ─────────────────────────────
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_RESOURCE_GROUP=rg-dataforge-dev
AZURE_LOCATION=eastus2

# ── Data Lake ────────────────────────────────────────────────
STORAGE_ACCOUNT_NAME=stadataforgedev
DATA_LAKE_CONTAINER_BRONZE=bronze
DATA_LAKE_CONTAINER_SILVER=silver
DATA_LAKE_CONTAINER_GOLD=gold

# ── Database (Local PostgreSQL) ──────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=dataforge
POSTGRES_USER=dataforge_admin
POSTGRES_PASSWORD=changeme_in_production

# ── Spark ────────────────────────────────────────────────────
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_MASTER_WEBUI_PORT=8080
SPARK_WORKER_WEBUI_PORT=8081
SPARK_WORKER_CORES=2
SPARK_WORKER_MEMORY=2G

# ── Databricks ───────────────────────────────────────────────
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_CLUSTER_ID=

# ── API Service ──────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true
API_LOG_LEVEL=info

# ── Monitoring ───────────────────────────────────────────────
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=dataforge123
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
LOKI_PORT=3100

# ── Data Generator ───────────────────────────────────────────
GENERATOR_NUM_CUSTOMERS=1000
GENERATOR_NUM_PRODUCTS=500
GENERATOR_NUM_ORDERS=10000
GENERATOR_DAYS_BACK=365
