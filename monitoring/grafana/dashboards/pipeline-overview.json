{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Pipeline Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "dataforge_pipeline_status",
          "legendFormat": "{{stage}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "FAILED", "color": "red" }, "1": { "text": "RUNNING", "color": "yellow" }, "2": { "text": "SUCCESS", "color": "green" } }, "type": "value" }
          ]
        }
      }
    },
    {
      "title": "Pipeline Duration (last run)",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "dataforge_pipeline_duration_seconds",
          "legendFormat": "{{stage}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 900 }
            ]
          }
        }
      }
    },
    {
      "title": "Records Processed (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(increase(dataforge_records_processed_total[24h]))",
          "legendFormat": "Total Records"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Data Quality Score",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "dataforge_quality_score_percent",
          "legendFormat": "Quality %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "title": "Records Processed Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "rate(dataforge_records_processed_total[5m])",
          "legendFormat": "{{layer}} / {{table}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Pipeline Failures Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "rate(dataforge_pipeline_failures_total[5m])",
          "legendFormat": "{{stage}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 20 } } }
    },
    {
      "title": "Layer Row Counts",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "dataforge_layer_row_count",
          "legendFormat": "{{layer}} — {{table}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Quality Checks Summary",
      "type": "piechart",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "dataforge_quality_checks_passed",
          "legendFormat": "Passed"
        },
        {
          "expr": "dataforge_quality_checks_failed",
          "legendFormat": "Failed"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["dataforge", "pipeline"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "title": "DataForge — Pipeline Overview",
  "uid": "dataforge-pipeline"
}
